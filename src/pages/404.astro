---
import Layout from '../layouts/Layout.astro';
import { languages } from '../utils/translations.js';
---

<Layout title="Broslunas Clock" description="404 - Page Not Found">
	<main class="app-container page-404">
		<div class="glass-card-404">
			<!-- Clock Icon with pulse & bounce animation -->
			<div class="icon-wrapper-404">
				<svg xmlns="http://www.w3.org/2000/svg" class="bell-icon-404" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
				</svg>
			</div>

			<!-- 404 Flip Clock Row -->
			<div class="flip-clock-row">
				<!-- Card 4 -->
				<div class="flip-card-404">
					<div class="glass-reflector"></div>
					<div class="card-panel-404 card-top-404">
						<span>4</span>
					</div>
					<div class="card-panel-404 card-bottom-404">
						<span>4</span>
					</div>
				</div>

				<!-- Card 0 -->
				<div class="flip-card-404">
					<div class="glass-reflector"></div>
					<div class="card-panel-404 card-top-404">
						<span>0</span>
					</div>
					<div class="card-panel-404 card-bottom-404">
						<span>0</span>
					</div>
				</div>

				<!-- Card 4 -->
				<div class="flip-card-404">
					<div class="glass-reflector"></div>
					<div class="card-panel-404 card-top-404">
						<span>4</span>
					</div>
					<div class="card-panel-404 card-bottom-404">
						<span>4</span>
					</div>
				</div>
			</div>

			<h2 id="title-404" class="title-404">404</h2>
			<p id="desc-404" class="desc-404">Oops! Page not found.</p>

			<a href="/" id="back-home-btn" class="control-btn play-btn back-home-btn">
				Go Back Home
			</a>
		</div>
	</main>

	<!-- Client-side localization script -->
	<script is:inline define:vars={{ languages }}>
		// Detect locale based on pathname
		const lang = window.location.pathname.startsWith('/en') ? 'en' : 'es';
		const t = languages[lang];

		// Set page meta title dynamically
		document.title = t.title_404;

		// Set text elements
		const titleEl = document.getElementById('title-404');
		const descEl = document.getElementById('desc-404');
		const btnEl = document.getElementById('back-home-btn');

		if (titleEl) titleEl.textContent = t.subheading_404;
		if (descEl) descEl.textContent = t.desc_404;
		if (btnEl) {
			btnEl.textContent = t.btn_back_home;
			btnEl.href = lang === 'en' ? '/en/' : '/';
		}
	</script>
</Layout>

<style>
	.page-404 {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		min-height: 100vh;
		padding: 24px;
		text-align: center;
	}

	.glass-card-404 {
		max-width: 440px;
		width: 100%;
		background: var(--glass-bg);
		border: 1px solid var(--glass-border);
		backdrop-filter: blur(40px);
		-webkit-backdrop-filter: blur(40px);
		border-radius: 32px;
		padding: 40px;
		box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 24px;
		transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
		animation: overlayFadeIn 0.5s forwards;
	}

	.glass-card-404:hover {
		transform: scale(1.02);
	}

	.icon-wrapper-404 {
		width: 80px;
		height: 80px;
		background: rgba(255, 149, 0, 0.15);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--accent-color);
		animation: pulseGlow 2s infinite;
	}

	.bell-icon-404 {
		width: 40px;
		height: 40px;
		animation: bounce404 2s infinite;
	}

	@keyframes bounce404 {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-8px); }
	}

	/* Custom Flip Clock digit cards for 404 */
	.flip-card-404 {
		position: relative;
		width: 76px;
		height: 100px;
		box-shadow: 0 15px 35px var(--shadow-color);
		border-radius: 12px;
	}

	.flip-card-404::after {
		content: '';
		position: absolute;
		left: 0;
		top: calc(50% - 1px);
		width: 100%;
		height: 2px;
		background: rgba(0, 0, 0, 0.7);
		z-index: 45;
		box-shadow: 0 1px 0px rgba(255, 255, 255, 0.07);
	}

	.card-panel-404 {
		position: absolute;
		left: 0;
		width: 100%;
		height: 50%;
		overflow: hidden;
		background: var(--flip-bg);
	}

	.card-panel-404 span {
		position: absolute;
		left: 0;
		width: 100%;
		height: 100px;
		line-height: 100px;
		text-align: center;
		font-size: 4.8rem;
		font-weight: 800;
		color: var(--flip-text);
		font-family: var(--font-sans);
		text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
	}

	.card-top-404 {
		top: 0;
		border-top-left-radius: 12px;
		border-top-right-radius: 12px;
		border-bottom: none;
		background: linear-gradient(to bottom, var(--flip-bg), rgba(0, 0, 0, 0.35));
	}

	.card-top-404 span {
		top: 0;
	}

	.card-bottom-404 {
		bottom: 0;
		border-bottom-left-radius: 12px;
		border-bottom-right-radius: 12px;
		border-top: none;
		background: linear-gradient(to top, var(--flip-bg), rgba(255, 255, 255, 0.03));
	}

	.card-bottom-404 span {
		top: -50px;
	}

	.title-404 {
		font-size: 1.6rem;
		font-weight: 800;
		color: #fff;
		margin-top: 8px;
	}

	.desc-404 {
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.6);
		line-height: 1.6;
		max-width: 320px;
		margin-bottom: 8px;
	}

	.back-home-btn {
		text-decoration: none;
		width: 100%;
		max-width: 220px;
	}
</style>
