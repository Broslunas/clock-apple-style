---
import Layout from '../../layouts/Layout.astro';
import FlipCard from '../../components/FlipCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import SettingsPanel from '../../components/SettingsPanel.astro';
import { languages } from '../../utils/translations.js';

const locale = Astro.currentLocale || 'es';
const t = languages[locale];
---

<Layout 
	title={t.title_timer} 
	description={t.desc_timer}
>
	<!-- CONTENEDOR PRINCIPAL -->
	<main class="app-container" id="app-canvas">
		<header class="app-header">
			<h1 class="brand-title">{t.title_clock}</h1>
			<!-- Indicador rápido de sonido / alarma activa -->
			<div class="status-indicator">
				<span id="active-alarms-badge" class="alarm-badge-status" style="display:none;">{t.active_alarms}</span>
			</div>
		</header>

		<!-- CONTENEDOR DE PERSPECTIVA 3D -->
		<div class="parallax-wrapper" id="parallax-target" transition:animate="fade">
			<!-- ==============================================
			     VISTA 4: TEMPORIZADOR (TIMER) 
			     ============================================== -->
			<section class="view-panel active" id="view-timer">
				<h2 class="view-title">{t.timer_title}</h2>

				<div class="progress-ring-container">
					<svg class="progress-ring-svg" width="300" height="300">
						<circle class="progress-ring-bg" cx="150" cy="150" r="135" />
						<circle class="progress-ring-bar" id="timer-progress-bar" cx="150" cy="150" r="135" />
					</svg>

					<div class="clock-inside-ring">
						<div class="flip-clock-row compact">
							<div class="flip-group">
								<FlipCard id="tm-h1" transitionName="card-h1" />
								<FlipCard id="tm-h2" transitionName="card-h2" />
							</div>
							<div class="colon">:</div>
							<div class="flip-group">
								<FlipCard id="tm-m1" transitionName="card-m1" />
								<FlipCard id="tm-m2" transitionName="card-m2" />
							</div>
							<div class="colon">:</div>
							<div class="flip-group">
								<FlipCard id="tm-s1" transitionName="card-s1" />
								<FlipCard id="tm-s2" transitionName="card-s2" />
							</div>
						</div>
					</div>
				</div>

				<div class="controls-row">
					<button id="timer-start-btn" class="control-btn play-btn">{t.sw_btn_start}</button>
					<button id="timer-reset-btn" class="control-btn border-btn">{t.sw_btn_reset}</button>
				</div>

				<div class="presets-row" id="timer-presets">
					<button class="preset-pill" data-seconds="60">1m</button>
					<button class="preset-pill" data-seconds="300">5m</button>
					<button class="preset-pill" data-seconds="600">10m</button>
					<button class="preset-pill active" data-seconds="1800">30m</button>
					<button class="preset-pill" data-seconds="3600">1h</button>
				</div>
			</section>
		</div>

		<!-- MENU LATERAL -->
		<Sidebar />

		<!-- PANEL DE AJUSTES -->
		<SettingsPanel />

		<!-- TOAST INICIAL DE ATAJOS -->
		<div class="toast-tip" id="toast-tip" set:html={t.toast_hint_html}></div>

		<!-- OVERLAY DE ALARMA DISPARADA -->
		<div class="alarm-triggered-overlay" id="alarm-triggered-overlay" style="display:none;">
			<div class="alarm-triggered-box">
				<div class="alarm-bell-icon">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
						<path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
					</svg>
				</div>
				<h2 id="triggered-alarm-label">{t.alarm_triggered_label_default}</h2>
				<p id="triggered-alarm-time">00:00</p>
				<div class="overlay-controls">
					<button class="overlay-btn snooze" id="btn-alarm-snooze">{t.alarm_btn_snooze}</button>
					<button class="overlay-btn dismiss" id="btn-alarm-dismiss">{t.alarm_btn_dismiss}</button>
				</div>
			</div>
		</div>
	</main>
</Layout>

<script src="../../utils/app.js"></script>
