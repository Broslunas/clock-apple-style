---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import SettingsPanel from '../../components/SettingsPanel.astro';
import { languages } from '../../utils/translations.js';

const locale = Astro.currentLocale || 'es';
const t = languages[locale];
---

<Layout 
	title={t.title_world_clock} 
	description={t.desc_world_clock}
	keywords={t.kw_world_clock}
	ogImage="/og-world-clock.png"
>
	<main class="app-container" id="app-canvas">
		<header class="app-header">
			<h1 class="brand-title">{t.title_clock}</h1>
			<div class="status-indicator">
				<span id="active-alarms-badge" class="alarm-badge-status" style="display:none;">{t.active_alarms}</span>
			</div>
		</header>

		<div class="parallax-wrapper" id="parallax-target" transition:animate="fade">
			<section class="view-panel active" id="view-world-clock">

				<div class="wc-search-container">
					<div class="timezone-search-box">
						<input
							type="text"
							id="timezone-search"
							class="timezone-search-input"
							placeholder={t.wc_search_placeholder}
							autocomplete="off"
						/>
						<div id="timezone-dropdown" class="timezone-dropdown-list" style="display:none;">
						</div>
					</div>
					<button id="wc-add-btn" class="wc-add-clock-btn">
						{t.wc_add_timezone}
					</button>
				</div>

				<div id="world-clocks-grid" class="world-clocks-grid"></div>

			</section>
		</div>

		<Sidebar />
		<SettingsPanel />
		<div class="toast-tip" id="toast-tip" set:html={t.toast_hint_html}></div>

		<div class="alarm-triggered-overlay" id="alarm-triggered-overlay" style="display:none;">
			<div class="alarm-triggered-box">
				<div class="alarm-bell-icon">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
						<path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
					</svg>
				</div>
				<h2 id="triggered-alarm-label">{t.alarm_triggered_label_default}</h2>
				<p id="triggered-alarm-time">00:00</p>
				<div class="overlay-controls">
					<button class="overlay-btn snooze" id="btn-alarm-snooze">{t.alarm_btn_snooze}</button>
					<button class="overlay-btn dismiss" id="btn-alarm-dismiss">{t.alarm_btn_dismiss}</button>
				</div>
			</div>
		</div>
	</main>
</Layout>

<style>
	.wc-search-container {
		display: flex;
		gap: 10px;
		align-items: center;
		margin-bottom: 24px;
		flex-wrap: wrap;
		justify-content: center;
		width: 100%;
		max-width: 700px;
	}

	.timezone-search-box {
		position: relative;
		flex: 1;
		min-width: 220px;
	}

	.timezone-search-input {
		width: 100%;
		height: 44px;
		background: rgba(255, 255, 255, 0.07);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 14px;
		color: #fff;
		padding: 0 16px;
		font-size: 0.9rem;
		font-family: var(--font-sans);
		backdrop-filter: blur(12px);
		outline: none;
		transition: border-color 0.2s;
		box-sizing: border-box;
	}

	.timezone-search-input:focus { border-color: var(--accent-color); }

	.timezone-dropdown-list {
		position: absolute;
		top: calc(100% + 6px);
		left: 0;
		right: 0;
		background: rgba(28, 28, 30, 0.95);
		backdrop-filter: blur(30px);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 14px;
		z-index: 500;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
	}

	:global(.timezone-item) {
		padding: 10px 16px;
		font-size: 0.88rem;
		color: rgba(255, 255, 255, 0.85);
		cursor: pointer;
		border-bottom: 1px solid rgba(255, 255, 255, 0.04);
		transition: background 0.15s;
	}

	:global(.timezone-item:hover) {
		background: rgba(255, 255, 255, 0.06);
		color: var(--accent-color);
	}

	.wc-add-clock-btn {
		height: 44px;
		padding: 0 20px;
		background: var(--accent-color);
		border: none;
		border-radius: 14px;
		color: #000;
		font-size: 0.88rem;
		font-weight: 700;
		cursor: pointer;
		transition: all 0.2s;
		white-space: nowrap;
		font-family: var(--font-sans);
	}

	.wc-add-clock-btn:hover { transform: translateY(-1px); filter: brightness(1.1); }
	.wc-add-clock-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

	.world-clocks-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 16px;
		width: 100%;
		max-width: 960px;
	}

	:global(.world-clock-card) {
		background: var(--glass-bg);
		border: 1px solid var(--glass-border);
		border-radius: 20px;
		padding: 20px 22px;
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
		transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.25s;
	}

	:global(.world-clock-card:hover) { transform: translateY(-3px); box-shadow: 0 14px 40px rgba(0, 0, 0, 0.3); }
	:global(.wc-card-header) { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
	:global(.wc-card-location) { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--accent-color); }
	:global(.wc-card-actions) { display: flex; gap: 6px; }
	:global(.wc-remove-btn) { width: 28px; height: 28px; border-radius: 50%; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.08); color: rgba(255,255,255,0.6); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
	:global(.wc-remove-btn:hover) { background: rgba(255,69,58,0.15); color: #ff453a; border-color: rgba(255,69,58,0.3); }
	:global(.wc-card-time) { display: flex; align-items: baseline; gap: 4px; line-height: 1; }
	:global(.wc-hours), :global(.wc-minutes) { font-size: clamp(2.4rem, 5vw, 3.2rem); font-weight: 800; color: var(--flip-text); font-family: var(--font-mono); letter-spacing: -2px; }
	:global(.wc-colon), :global(.wc-colon-s) { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 800; color: var(--accent-color); font-family: var(--font-mono); animation: blink-colon 1s step-end infinite; }
	:global(.wc-seconds) { font-size: clamp(1.4rem, 2.5vw, 1.8rem); font-weight: 700; color: rgba(255,255,255,0.5); font-family: var(--font-mono); }
	:global(.wc-ampm) { font-size: 0.85rem; font-weight: 700; color: var(--accent-color); align-self: center; padding-left: 4px; }
	:global(.wc-card-date) { font-size: 0.72rem; font-weight: 600; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 1.5px; margin-top: 8px; }

	@keyframes blink-colon { 50% { opacity: 0.2; } }

	#view-world-clock { display: flex; flex-direction: column; align-items: center; width: 100%; max-width: 1000px; gap: 0; padding-top: 20px; }

	@media (max-width: 600px) {
		.world-clocks-grid { grid-template-columns: 1fr; }
		.wc-search-container { flex-direction: column; align-items: stretch; }
		.wc-add-clock-btn { width: 100%; }
	}
</style>

<script src="../../utils/app.js"></script>
