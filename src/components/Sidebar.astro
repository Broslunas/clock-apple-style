---
import { languages } from '../utils/translations.js';
const locale = Astro.currentLocale || 'es';
const t = languages[locale];
const prefix = locale === 'en' ? '/en' : locale === 'fr' ? '/fr' : locale === 'pt' ? '/pt' : locale === 'de' ? '/de' : '';
---

<!-- Botón de Hamburguesa Flotante Premium -->
<button class="hamburger-trigger" id="hamburger-btn" aria-label="Abrir menú" aria-expanded="false" transition:persist>
    <svg class="hamburger-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line class="line-top" x1="4" y1="6" x2="20" y2="6"></line>
        <line class="line-mid" x1="4" y1="12" x2="20" y2="12"></line>
        <line class="line-bot" x1="4" y1="18" x2="20" y2="18"></line>
    </svg>
</button>

<!-- Menú Lateral Colapsable (Sidebar Drawer) -->
<nav class="sidebar-container" id="app-sidebar" aria-label="Menú principal lateral" transition:persist>
    <div class="sidebar-brand">
        <svg xmlns="http://www.w3.org/2000/svg" class="logo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        <span class="brand-text">Broslunas Clock</span>
    </div>

    <div class="sidebar-menu">
        <!-- Reloj (Clock) -->
        <a href={`${prefix}/`} class="menu-item active" data-view="clock" title={`${t.menu_clock} (Atajo: 1 / C)`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            <span>{t.menu_clock}</span>
            <kbd class="key-hint">1</kbd>
        </a>

        <!-- Cronómetro (Stopwatch) -->
        <a href={`${prefix}/stopwatch`} class="menu-item" data-view="stopwatch" title={`${t.menu_stopwatch} (Atajo: 2 / S)`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="10" y1="2" x2="14" y2="2"></line>
                <line x1="12" y1="14" x2="15" y2="11"></line>
                <circle cx="12" cy="14" r="8"></circle>
            </svg>
            <span>{t.menu_stopwatch}</span>
            <kbd class="key-hint">2</kbd>
        </a>

        <!-- Pomodoro -->
        <a href={`${prefix}/pomodoro`} class="menu-item" data-view="pomodoro" title={`${t.menu_pomodoro} (Atajo: 3 / P)`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v4M4.22 5.78l2.83 2.83M19.78 5.78l-2.83 2.83"></path>
                <path d="M12 6c-3.87 0-7 2.69-7 6a7.1 7.1 0 0 0 2.24 5.16c.3.26.43.68.32 1.07L7 21h10l-.56-2.77c-.1-.39.02-.81.32-1.07A7.1 7.1 0 0 0 19 12c0-3.31-3.13-6-7-6z"></path>
            </svg>
            <span>{t.menu_pomodoro}</span>
            <kbd class="key-hint">3</kbd>
        </a>

        <!-- Temporizador (Timer) -->
        <a href={`${prefix}/timer`} class="menu-item" data-view="timer" title={`${t.menu_timer} (Atajo: 4 / T)`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                <path d="M2 12h20"></path>
            </svg>
            <span>{t.menu_timer}</span>
            <kbd class="key-hint">4</kbd>
        </a>
        
        <!-- Reloj Mundial (World Clock) -->
        <a href={`${prefix}/world-clock`} class="menu-item" data-view="world-clock" title={`${t.menu_world_clock} (Atajo: 5 / W)`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
                <path d="M2 12h20"></path>
            </svg>
            <span>{t.menu_world_clock}</span>
            <kbd class="key-hint">5</kbd>
        </a>

    </div>

    <div class="sidebar-footer">
        <!-- Silenciar (Mute) -->
        <button class="footer-btn" id="sidebar-mute-btn" title={`${t.menu_sound} (Atajo: M)`}>
            <svg xmlns="http://www.w3.org/2000/svg" class="vol-icon-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" class="vol-icon-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="display:none;">
                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                <line x1="23" y1="9" x2="17" y2="15"></line>
                <line x1="17" y1="9" x2="23" y2="15"></line>
            </svg>
            <span class="footer-btn-text">{t.menu_sound}</span>
        </button>

        <!-- Ajustes (Settings) -->
        <button class="footer-btn" id="sidebar-settings-btn" title={`${t.menu_settings} (Atajo: .)`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
            <span class="footer-btn-text">{t.menu_settings}</span>
        </button>
    </div>
</nav>

<style>
    /* Trigger de Hamburguesa Flotante */
    .hamburger-trigger {
        position: fixed;
        top: 24px;
        left: 24px;
        z-index: 1100;
        width: 44px;
        height: 44px;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-radius: 12px;
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25), 
                    inset 0 1px 0 rgba(255, 255, 255, 0.05);
        transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .hamburger-trigger:hover {
        background: rgba(255, 255, 255, 0.1);
        transform: scale(1.05);
    }

    /* Animación del icono de hamburguesa SVG a cruz */
    .hamburger-svg {
        width: 20px;
        height: 20px;
        color: #fff;
        transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .hamburger-svg line {
        transform-origin: 12px 12px;
        transform-box: viewBox;
        transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), 
                    stroke 0.4s cubic-bezier(0.25, 1, 0.5, 1), 
                    opacity 0.3s;
    }

    .hamburger-trigger[aria-expanded="true"] .hamburger-svg {
        transform: rotate(180deg);
    }

    .hamburger-trigger[aria-expanded="true"] .line-top {
        transform: translateY(6px) rotate(45deg);
        stroke: var(--accent-color);
    }

    .hamburger-trigger[aria-expanded="true"] .line-mid {
        opacity: 0;
    }

    .hamburger-trigger[aria-expanded="true"] .line-bot {
        transform: translateY(-6px) rotate(-45deg);
        stroke: var(--accent-color);
    }

    /* CONTENEDOR DE SIDEBAR LATERAL (DRAWER) */
    .sidebar-container {
        position: fixed;
        top: 0;
        bottom: 0;
        left: -260px; /* Escondido por defecto */
        width: 250px;
        background: rgba(20, 20, 22, 0.7);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border-right: 1px solid var(--glass-border);
        box-shadow: 15px 0 45px rgba(0, 0, 0, 0.4);
        padding: 92px 18px 24px 18px; /* Margen superior para el trigger */
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        z-index: 1050;
        transition: left 0.45s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .sidebar-container.open {
        left: 0;
    }

    /* Marca / Logo */
    .sidebar-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        padding-bottom: 24px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        margin-bottom: 24px;
    }

    .logo-icon {
        width: 24px;
        height: 24px;
        color: var(--accent-color);
    }

    .brand-text {
        font-weight: 800;
        font-size: 1.15rem;
        letter-spacing: -0.5px;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .brand-text .badge {
        font-size: 0.65rem;
        font-weight: 800;
        background: var(--accent-color);
        color: #000;
        padding: 2px 6px;
        border-radius: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Menú */
    .sidebar-menu {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex-grow: 1;
    }

    .menu-item {
        position: relative;
        display: flex;
        align-items: center;
        gap: 14px;
        width: 100%;
        padding: 12px 16px;
        border: none;
        background: transparent;
        color: #fff;
        cursor: pointer;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.25s cubic-bezier(0.25, 1, 0.5, 1);
        text-align: left;
    }

    .menu-item svg {
        width: 20px;
        height: 20px;
        opacity: 0.6;
        transition: opacity 0.2s, transform 0.2s;
    }

    .menu-item:hover {
        background: rgba(255, 255, 255, 0.06);
    }

    .menu-item:hover svg {
        opacity: 1;
        color: var(--accent-color);
        transform: scale(1.05);
    }

    .menu-item.active {
        background: rgba(255, 255, 255, 0.1);
        color: var(--accent-color);
        box-shadow: inset 1px 1px 0 rgba(255, 255, 255, 0.05);
    }

    .menu-item.active::before {
        content: '';
        position: absolute;
        left: 0;
        top: 25%;
        height: 50%;
        width: 3px;
        background: var(--accent-color);
        border-radius: 0 4px 4px 0;
        box-shadow: 0 0 8px var(--accent-color);
    }

    .menu-item.active svg {
        opacity: 1;
        color: var(--accent-color);
    }

    /* Píldora de atajo visual */
    .key-hint {
        margin-left: auto;
        font-size: 0.65rem;
        font-family: var(--font-mono);
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.4);
        padding: 2px 6px;
        border-radius: 4px;
        text-transform: uppercase;
        font-weight: 700;
    }

    .menu-item:hover .key-hint {
        color: #fff;
        background: rgba(255, 255, 255, 0.15);
    }

    /* Pie de Sidebar (Footer) */
    .sidebar-footer {
        display: flex;
        gap: 8px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 20px;
    }

    .footer-btn {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        height: 64px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        color: #fff;
        cursor: pointer;
        font-size: 0.72rem;
        font-weight: 600;
        transition: all 0.25s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .footer-btn svg {
        width: 18px;
        height: 18px;
        opacity: 0.6;
        transition: all 0.2s;
    }

    .footer-btn:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.05);
    }

    .footer-btn:hover svg {
        opacity: 1;
        color: var(--accent-color);
    }

    .footer-btn.active {
        background: rgba(255, 255, 255, 0.08);
        color: var(--accent-color);
    }

    .footer-btn.active svg {
        opacity: 1;
        color: var(--accent-color);
    }

    @media (max-width: 600px) {
        .sidebar-container {
            width: 100%;
            left: -100%;
            border-right: none;
        }
    }
</style>
