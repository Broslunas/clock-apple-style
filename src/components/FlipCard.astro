---
interface Props {
	id: string;
	label?: string;
}

const { id, label } = Astro.props;
---

<div class="flip-card-wrapper">
	<div class="flip-card" id={id}>
		<!-- Reflector de vidrio para darle realismo 3D -->
		<div class="glass-reflector"></div>
		
		<!-- Mitad Superior -->
		<div class="card-panel card-top">
			<span>0</span>
		</div>
		
		<!-- Mitad Inferior -->
		<div class="card-panel card-bottom">
			<span>0</span>
		</div>
	</div>
	{label && <div class="card-label">{label}</div>}
</div>

<style is:global>
	:root {
		--card-width: 120px;
		--card-height: 160px;
		--card-font-size: 7.5rem;
		--card-radius: 18px;
	}

	.flip-card-wrapper {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 12px;
	}

	.flip-card {
		position: relative;
		width: var(--card-width);
		height: var(--card-height);
		perspective: 600px;
		box-shadow: 0 20px 45px var(--shadow-color), 
		            inset 0 1px 0 rgba(255, 255, 255, 0.1);
		border-radius: var(--card-radius);
		transition: transform 0.1s ease-out;
	}

	/* Reflector de vidrio */
	.glass-reflector {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		border-radius: var(--card-radius);
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0) 50%, rgba(0, 0, 0, 0.15) 100%);
		z-index: 50;
		pointer-events: none;
		border: 1px solid var(--card-border);
	}

	.card-panel {
		position: absolute;
		left: 0;
		width: 100%;
		height: 50%;
		overflow: hidden;
		background: var(--flip-bg);
		transition: background 0.8s cubic-bezier(0.25, 1, 0.5, 1);
	}

	.card-panel span, .flipper-falling span {
		position: absolute;
		left: 0;
		width: 100%;
		height: var(--card-height);
		line-height: var(--card-height);
		text-align: center;
		font-size: var(--card-font-size);
		font-weight: 800;
		color: var(--flip-text);
		font-family: var(--font-sans);
		text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
	}

	/* Mitad superior */
	.card-top {
		top: 0;
		border-top-left-radius: var(--card-radius);
		border-top-right-radius: var(--card-radius);
		border-bottom: none;
		background: linear-gradient(to bottom, var(--flip-bg), rgba(0, 0, 0, 0.35));
	}

	.card-top span {
		top: 0;
	}

	/* Mitad inferior */
	.card-bottom {
		bottom: 0;
		border-bottom-left-radius: var(--card-radius);
		border-bottom-right-radius: var(--card-radius);
		border-top: none;
		background: linear-gradient(to top, var(--flip-bg), rgba(255, 255, 255, 0.03));
	}

	.card-bottom span {
		top: calc(var(--card-height) / -2);
	}

	/* Línea central realista */
	.flip-card::after {
		content: '';
		position: absolute;
		left: 0;
		top: calc(50% - 1px);
		width: 100%;
		height: 2px;
		background: rgba(0, 0, 0, 0.7);
		z-index: 45;
		box-shadow: 0 1px 0px rgba(255, 255, 255, 0.07);
	}

	/* Pestaña animada que cae */
	.flipper-falling {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 50%;
		background: var(--flip-bg);
		border-top-left-radius: var(--card-radius);
		border-top-right-radius: var(--card-radius);
		overflow: hidden;
		transform-origin: bottom center;
		animation: flipDown 0.38s cubic-bezier(0.25, 1, 0.5, 1) forwards;
		z-index: 30;
		backface-visibility: hidden;
		box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
		border: 1px solid var(--card-border);
		border-bottom: none;
	}

	.flipper-falling span {
		top: 0;
	}

	@keyframes flipDown {
		0% {
			transform: rotateX(0deg);
			filter: brightness(1);
		}
		50% {
			filter: brightness(0.7);
		}
		100% {
			transform: rotateX(-180deg);
			filter: brightness(0.4);
		}
	}

	.card-label {
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 2px;
		opacity: 0.45;
		transition: opacity 0.3s;
	}

	.flip-card-wrapper:hover .card-label {
		opacity: 0.8;
	}

	/* Responsivo con CSS Custom Properties */
	@media (max-width: 900px) {
		:root {
			--card-width: 90px;
			--card-height: 120px;
			--card-font-size: 5.5rem;
			--card-radius: 14px;
		}
	}

	@media (max-width: 600px) {
		:root {
			--card-width: 54px;
			--card-height: 72px;
			--card-font-size: 3.3rem;
			--card-radius: 8px;
		}
		.card-label {
			font-size: 0.65rem;
			letter-spacing: 1px;
		}
	}
</style>
